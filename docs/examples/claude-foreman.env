# Claude Foreman crew identity - copy to local config/claude-foreman.env.
# With this file AND the app's private key at config/claude-foreman.pem
# present, fm-spawn mints a per-task GitHub App installation token so
# crewmates author commits and PRs as <app-slug>[bot] instead of the
# captain's personal account. Absent either file, spawns are unchanged.
# NEVER commit the .pem; both files are gitignored.
FM_FOREMAN_APP_ID=4034902
FM_FOREMAN_INSTALLATION_ID=139779760
# Optional; defaults shown.
#FM_FOREMAN_APP_SLUG=claude-foreman
#FM_FOREMAN_PEM=/absolute/path/to/config/claude-foreman.pem
