{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/forms/**",
              "components/surfaces/**",
              "components/terminal/**",
              "ui_kits/homemux-ios/**",
              "ui_kits/homemux-ios/screens/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|radius|bare|glow|key|ref|className|style|children)$/]",
        "message": "<AppIcon> doesn't accept that prop. Declared props: size, radius, bare, glow."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tint|variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tint, variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:tinted|outline|solid)$/]",
        "message": "<Badge> variant must be one of 'tinted' | 'outline' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|title|message|action|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: tone, icon, title, message, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:warning|danger|accent|info)$/]",
        "message": "<Banner> tone must be one of 'warning' | 'danger' | 'accent' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|destructive|fullWidth|icon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, destructive, fullWidth, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:prominent|bordered|plain)$/]",
        "message": "<Button> variant must be one of 'prominent' | 'bordered' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:large|small)$/]",
        "message": "<Button> size must be one of 'large' | 'small'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|accent|padding|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, accent, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|material|raised)$/]",
        "message": "<Card> variant must be one of 'solid' | 'material' | 'raised'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|color|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|label|size|shape|variant|tint|iconSize|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: name, label, size, shape, variant, tint, iconSize."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:rounded|circle)$/]",
        "message": "<IconButton> shape must be one of 'rounded' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:material|soft|plain)$/]",
        "message": "<IconButton> variant must be one of 'material' | 'soft' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KeyCap'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|children|key|ref|className|style|children)$/]",
        "message": "<KeyCap> doesn't accept that prop. Declared props: active, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:leading|title|subtitle|detail|trailing|chevron|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: leading, title, subtitle, detail, trailing, chevron."
      },
      {
        "selector": "JSXOpeningElement[name.name='PaletteDots'] > JSXAttribute > JSXIdentifier[name!=/^(?:theme|size|ring|key|ref|className|style|children)$/]",
        "message": "<PaletteDots> doesn't accept that prop. Declared props: theme, size, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|size|pulse|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: state, size, pulse."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:connected|connecting|failed|idle)$/]",
        "message": "<StatusDot> state must be one of 'connected' | 'connecting' | 'failed' | 'idle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|placeholder|mono|leading|footnote|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, value, onChange, placeholder, mono, leading, footnote."
      },
      {
        "selector": "JSXOpeningElement[name.name='ThemePreviewCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:theme|showTitle|key|ref|className|style|children)$/]",
        "message": "<ThemePreviewCard> doesn't accept that prop. Declared props: theme, showTitle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|mark|color|accent|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: size, mark, color, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='mark'] > Literal[value!=/^(?:tile|bare)$/]",
        "message": "<Wordmark> mark must be one of 'tile' | 'bare'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
